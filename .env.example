DRIVER=~fastapi+~websockets
HOST=127.0.0.1
PORT=8080

ONEBOT_V11_ACCESS_TOKEN=change-me-to-a-long-random-token

QGUARD_DB_URL=sqlite+aiosqlite:///./data/qguard.db
QGUARD_SUPER_ADMINS=[1348984838]
QGUARD_DEFAULT_ENABLE=true
QGUARD_DEFAULT_MUTE_SECONDS=600
QGUARD_MESSAGE_CACHE_DAYS=7
QGUARD_CARD_LOCK_PATROL_INTERVAL_SECONDS=600
QGUARD_AUTO_PATROL_INTERVAL_SECONDS=1800
QGUARD_ENABLE_AUTO_MODERATION=true
QGUARD_ENABLE_MESSAGE_CACHE=true
QGUARD_COMMAND_PREFIX=/管

AI_CORE_PROVIDER=deepseek
AI_CORE_BASE_URL=https://api.deepseek.com
AI_CORE_API_KEY=sk-change-me
AI_CORE_MODEL=deepseek-chat
AI_CORE_TIMEOUT_SECONDS=45
AI_CORE_MAX_TOKENS=2048
AI_CORE_TEMPERATURE=0.2
AI_CORE_ENABLE_CACHE=true
AI_CORE_CACHE_TTL_SECONDS=86400
AI_CORE_DAILY_LIMIT_PER_USER=30
AI_CORE_DAILY_LIMIT_PER_GROUP=300
AI_CORE_GLOBAL_DAILY_LIMIT=5000
AI_CORE_ENABLE_JSON_REPAIR=true
AI_CORE_ENABLE_CONTENT_MASK=true
AI_CORE_LOG_PROMPT=false
AI_CORE_LOG_RESPONSE=false
AI_CORE_DB_URL=sqlite+aiosqlite:///./data/ai_core.db
AI_CORE_SUPER_ADMINS=[1348984838]

LOG_DOCTOR_DB_URL=sqlite+aiosqlite:///./data/log_doctor.db
LOG_DOCTOR_ENABLE_AI=true
LOG_DOCTOR_MAX_INPUT_CHARS=12000
LOG_DOCTOR_MAX_REPLY_CHARS=1200
LOG_DOCTOR_RULE_CONFIDENCE_THRESHOLD=0.85

GROUP_WIKI_DB_URL=sqlite+aiosqlite:///./data/group_wiki.db
GROUP_WIKI_ENABLE_AI=true
GROUP_WIKI_DEFAULT_SCOPE=global
GROUP_WIKI_IMPORT_DIR=./知识库
GROUP_WIKI_MAX_ARTICLE_LENGTH=20000
GROUP_WIKI_CHUNK_SIZE=800
GROUP_WIKI_CHUNK_OVERLAP=100
GROUP_WIKI_MAX_REPLY_CHARS=1200
GROUP_WIKI_SOFTWARE_NAME=QInEX
